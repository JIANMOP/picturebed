# Picturebed — Backend Configuration
# Uncomment and fill in the credentials for backends you want to use.
# These are loaded automatically and override any UI-configured values on startup.
# Restart the dev server after changing this file.

# --- GitHub ---
VITE_GITHUB_REPO=https://github.com/your-username/your-repo
VITE_GITHUB_BRANCH=master
VITE_GITHUB_TOKEN=ghp_your_personal_access_token
VITE_GITHUB_USE_CDN=false

# --- Gitee ---
VITE_GITEE_REPO=https://gitee.com/your-username/your-repo
VITE_GITEE_BRANCH=master
VITE_GITEE_TOKEN=your_gitee_access_token

# --- AliOSS ---
# VITE_ALIOSS_REGION=oss-cn-hangzhou
# VITE_ALIOSS_BUCKET=your-bucket
# VITE_ALIOSS_ACCESS_KEY_ID=your-access-key-id
# VITE_ALIOSS_ACCESS_KEY_SECRET=your-access-key-secret
# VITE_ALIOSS_PATH=images
# VITE_ALIOSS_CDN_HOST=https://cdn.example.com
# VITE_ALIOSS_USE_SSL=true

# --- Tencent COS ---
# VITE_TXCOS_REGION=ap-guangzhou
# VITE_TXCOS_BUCKET=your-bucket
# VITE_TXCOS_SECRET_ID=your-secret-id
# VITE_TXCOS_SECRET_KEY=your-secret-key
# VITE_TXCOS_PATH=images
# VITE_TXCOS_CDN_HOST=https://cdn.example.com

# --- Qiniu ---
# VITE_QINIU_ACCESS_KEY=your-access-key
# VITE_QINIU_SECRET_KEY=your-secret-key
# VITE_QINIU_BUCKET=your-bucket
# VITE_QINIU_REGION=z0
# VITE_QINIU_PATH=images
# VITE_QINIU_DOMAIN=https://cdn.example.com

# --- MinIO ---
# VITE_MINIO_ENDPOINT=minio.example.com
# VITE_MINIO_PORT=9000
# VITE_MINIO_USE_SSL=false
# VITE_MINIO_BUCKET=your-bucket
# VITE_MINIO_ACCESS_KEY=your-access-key
# VITE_MINIO_SECRET_KEY=your-secret-key

# --- S3 ---
# VITE_S3_ENDPOINT=https://s3.amazonaws.com
# VITE_S3_REGION=us-east-1
# VITE_S3_BUCKET=your-bucket
# VITE_S3_ACCESS_KEY_ID=your-access-key-id
# VITE_S3_ACCESS_KEY_SECRET=your-secret-key
# VITE_S3_PATH=images
# VITE_S3_CDN_HOST=https://cdn.example.com
# VITE_S3_PATH_STYLE=false

# --- Cloudflare R2 ---
# VITE_R2_ACCOUNT_ID=your-account-id
# VITE_R2_ACCESS_KEY=your-access-key
# VITE_R2_SECRET_KEY=your-secret-key
# VITE_R2_BUCKET=your-bucket
# VITE_R2_PATH=images
# VITE_R2_DOMAIN=https://cdn.example.com

# --- Upyun ---
# VITE_UPYUN_BUCKET=your-bucket
# VITE_UPYUN_OPERATOR=your-operator
# VITE_UPYUN_PASSWORD=your-password
# VITE_UPYUN_PATH=images
# VITE_UPYUN_DOMAIN=https://cdn.example.com

# --- Telegram ---
# VITE_TELEGRAM_TOKEN=your-bot-token
# VITE_TELEGRAM_CHAT_ID=your-chat-id

# --- WeChat MP ---
# VITE_MP_APP_ID=your-app-id
# VITE_MP_APP_SECRET=your-app-secret
# VITE_MP_PROXY_ORIGIN=https://your-proxy.com

# --- Cloudinary ---
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_API_KEY=your-api-key
# VITE_CLOUDINARY_API_SECRET=your-api-secret
# VITE_CLOUDINARY_UPLOAD_PRESET=your-preset
# VITE_CLOUDINARY_FOLDER=images
# VITE_CLOUDINARY_DOMAIN=https://cdn.example.com

# --- Default upload backend ---
# VITE_DEFAULT_BACKEND=github
